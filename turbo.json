{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "dev:demo": {
      "persistent": true,
      "cache": false
    },
    "demo": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    },
    "dev:log": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "outputs": [".next/**"]
    }
  }
}
